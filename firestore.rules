rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any logged-in user can read profiles (needed for NGO location lookup,
    // donor name fetch, etc). Only the owner can write their own profile.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Sub-collections (donation_history, pickup_history) — owner only
    match /users/{uid}/{sub}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /meals/{mealId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null &&
        resource.data.donorId == request.auth.uid;
    }

    match /notifications/{id} {
      allow read, update: if request.auth != null &&
        resource.data.toUid == request.auth.uid;
      allow create: if request.auth != null;
    }

    match /donor_notifications/{id} {
      allow read, update: if request.auth != null &&
        resource.data.toUid == request.auth.uid;
      allow create: if request.auth != null;
    }

    match /completion_notifications/{id} {
      allow read, update: if request.auth != null &&
        resource.data.toUid == request.auth.uid;
      allow create: if request.auth != null;
    }
  }
}
